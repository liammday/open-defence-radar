# Copy to .env and fill in. NEVER commit real keys.

# --- Generation (required for synthesis + the eval judge) ---
# Default provider is Gemini (Google AI Studio free tier — free key, no card):
#   https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# Alternative: Anthropic (pay-per-use API; NOT covered by a Claude Max/Pro sub):
ANTHROPIC_API_KEY=

# --- Provider selection (optional; defaults shown) ---
ODR_EMBEDDER=local          # local | voyage | openai
ODR_GENERATOR=gemini        # gemini | anthropic
ODR_GEMINI_MODEL=gemini-2.0-flash
ODR_ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Hosted embedding providers (only needed if ODR_EMBEDDER is not "local") ---
VOYAGE_API_KEY=
OPENAI_API_KEY=

# --- Storage ---
ODR_DB_PATH=data/odr.sqlite3

# --- Retrieval ---
ODR_RERANK=0                # 1 enables the eval-gated cross-encoder reranker
